# Environment Variables
# Copy this file to .env.local and fill in the values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here


# Cleanup API Key (used to protect the cleanup cron endpoint)
CLEANUP_API_KEY=your-cleanup-api-key-here

# Redis Configuration (e.g. Upstash Redis connection string URL)
REDIS_URL=redis://localhost:6379

# Cloudflare Turnstile Bot Protection (using testing keys by default)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
